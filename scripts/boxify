#!/bin/bash

function boxify {
	max_length=$(printf '%s\n' "$@" | sed -e 's/---//' -e 's/===//' | wc -L)

	#spaces=$(printf "%${max_length}s" '')
	inside_single=$(printf "%${max_length}s" '' | sed -e 's/ /─/g')
	inside_double=$(printf "%${max_length}s" '' | sed -e 's/ /═/g')

	middle_single=$(printf "├─${inside_single}─╢")
	mid_double=$(printf "╞═${inside_double}═╣")

	# ┌─────────╖
	printf "┌─${inside_single}─╖\n"

	while IFS= read -r line || [ -n "$line" ]
	do
		case "$line" in
			# ├─────────╢
			'---')
				printf "$middle_single\n"
				;;
			# ╞═════════╣
			'===')
				printf "$middle_double\n"
				;;
			# │ Example ║
			*)
				printf "│ %-${max_length}s ║\n" "$line"
				#this_length=$(($(echo "$line" | wc -m) - 1))
				#needed=$(( "${max_length}" - "${this_length}" ))
				#printf "│ %s%${needed}s ║\n" "${line}" ''
				;;
		esac
	done <<< $(printf '%s\n' "$@")

	# ╘═════════╝
	printf "╘═${inside_double}═╝\n"
}

# $ boxify 'a' 'bbbb' '---' 'c' '    d' '===' 'f'
# ┌────────╖
# │ a      ║
# │ bbbb   ║
# ├────────╢
# │ c      ║
# │     d  ║
# ╞════════╣
# │ f      ║
# ╘════════╝

boxify "$@"
